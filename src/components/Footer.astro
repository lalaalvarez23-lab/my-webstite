---
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <span class="logo">Laura Alvarez</span>
    <span class="copy">© {year} — Director &amp; Compositor</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding-block: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .copy {
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
