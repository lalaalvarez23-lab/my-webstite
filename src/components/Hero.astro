---
---

<section id="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="section-label">Director · Compositor</p>
      <h1>
        Laura<br />
        <span class="name-accent">Alvarez</span>
      </h1>
      <p class="tagline">
        Crafting visual worlds at the intersection of<br />
        architecture, film, and visual effects.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View Work</a>
        <a href="#contact" class="btn-ghost">Get in Touch</a>
      </div>
    </div>

    <div class="hero-decoration" aria-hidden="true">
      <div class="grid-lines"></div>
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span>scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  section {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    padding-top: 64px; /* header height */
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  h1 {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .name-accent {
    color: var(--accent);
  }

  .tagline {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 380px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-dim);
  }

  .btn-ghost {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--muted);
    color: var(--text);
  }

  /* ── Decoration grid ── */
  .hero-decoration {
    position: relative;
    height: 400px;
  }

  .grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-hint span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--muted), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-decoration {
      display: none;
    }
  }
</style>
