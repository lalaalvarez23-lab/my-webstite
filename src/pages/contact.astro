---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Contact — Laura Alvarez">
  <header>
    <a href={base} class="back">← Laura Alvarez</a>
    <nav>
      <a href={`${base}about`}>About</a>
      <a href={`${base}contact`} class="active">Contact</a>
    </nav>
  </header>

  <main>
    <div class="contact-card">
      <h1>Contact</h1>

      <div class="links">

        <a href="mailto:lauraalvarezfilm@gmail.com" class="link-item">
          <span class="icon">
            <!-- Email -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <span class="label">Email</span>
          <span class="value">lauraalvarezfilm@gmail.com</span>
          <span class="arrow">→</span>
        </a>

        <a href="https://www.linkedin.com/in/laura-alvarez-562055366" target="_blank" rel="noopener noreferrer" class="link-item">
          <span class="icon">
            <!-- LinkedIn -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </span>
          <span class="label">LinkedIn</span>
          <span class="value">Laura Alvarez</span>
          <span class="arrow">→</span>
        </a>

        <a href="https://filmfreeway.com/LauraMariaAlvarezCadena" target="_blank" rel="noopener noreferrer" class="link-item">
          <span class="icon">
            <!-- FilmFreeway - film reel icon -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>
              <circle cx="12" cy="5" r="1" fill="currentColor" stroke="none"/>
              <circle cx="12" cy="19" r="1" fill="currentColor" stroke="none"/>
              <circle cx="5" cy="12" r="1" fill="currentColor" stroke="none"/>
              <circle cx="19" cy="12" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </span>
          <span class="label">FilmFreeway</span>
          <span class="value">Laura Maria Alvarez Cadena</span>
          <span class="arrow">→</span>
        </a>

      </div>
    </div>
  </main>

  <footer>
    <span>Laura Alvarez — Director</span>
    <span>© 2026 All rights reserved</span>
  </footer>
</Layout>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
  }

  .back {
    font-size: 12px;
    color: #707070;
    transition: color 0.15s;
  }

  .back:hover { color: #1a1a1a; }

  nav {
    display: flex;
    gap: 24px;
  }

  nav a {
    font-size: 12px;
    color: #707070;
    transition: color 0.15s;
  }

  nav a:hover,
  nav a.active {
    color: #1a1a1a;
  }

  main {
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 56px;
  }

  .contact-card {
    width: min(480px, 100%);
    padding-inline: 24px;
  }

  @media (min-width: 769px) {
    .contact-card {
      padding-inline: 0;
    }
  }

  h1 {
    font-size: 12px;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 24px;
  }

  .links {
    border-top: 1px solid #e0e0e0;
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid #e0e0e0;
    transition: padding-left 0.2s;
  }

  .link-item:hover {
    padding-left: 6px;
  }

  .link-item:hover .arrow {
    color: #1a1a1a;
  }

  .icon {
    color: #707070;
    display: flex;
    align-items: center;
  }

  .label {
    font-size: 11px;
    color: #1a1a1a;
    min-width: 90px;
    letter-spacing: 0.05em;
  }

  .value {
    flex: 1;
    font-size: 12px;
    color: #707070;
  }

  .arrow {
    font-size: 12px;
    color: #c0c0c0;
    transition: color 0.2s;
  }

  footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 20px 24px;
    font-size: 11px;
    color: #707070;
  }

  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-align: center;
    }
  }
</style>
