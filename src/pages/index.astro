---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const project = {
  title: 'Desierto',
  category: 'Music Video',
  year: '2026',
  image: `${base}images/desierto.jpg`,
  link: `${base}projects/desierto`,
};
---

<Layout title="Laura Alvarez">
  <Header />

  <main>
    <a href={project.link} class="project-card">
      <div class="thumb">
        {project.image
          ? <img src={project.image} alt={project.title} />
          : <div class="placeholder" />
        }
      </div>
      <div class="meta">
        <span class="title">{project.title}</span>
        <span class="info">{project.category}, {project.year}</span>
      </div>
    </a>
  </main>

  <footer>
    <span>Director · Compositor</span>
    <span>© {new Date().getFullYear()}</span>
  </footer>
</Layout>

<style>
  main {
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card {
    display: block;
    width: 320px;
    cursor: pointer;
  }

  .thumb {
    width: 320px;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: #f0f0f0;
    margin-bottom: 10px;
    transition: opacity 0.3s ease;
  }

  @media (max-width: 768px) {
    .project-card,
    .thumb {
      width: min(280px, 78vw);
    }
  }

  .project-card:hover .thumb {
    opacity: 0.75;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: #e8e8e8;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .project-card:hover img {
    transform: scale(1.03);
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .title {
    font-size: 12px;
    color: var(--text);
  }

  .info {
    font-size: 11px;
    color: var(--muted);
  }

  footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 20px 24px;
    font-size: 11px;
    color: var(--muted);
  }
</style>
